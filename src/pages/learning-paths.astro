---
import BaseLayout from '../layouts/BaseLayout.astro';
import { withBase } from '../lib/base';
import {
  CORE_SECTIONS,
  FINISH_SECTION,
  PATHS,
  REAL_WORLD_DOMAINS,
  START_SECTION,
  getDomains,
  getSections,
  sectionHref,
} from '../lib/paths';

const start = getSections([START_SECTION])[0];
const core = getSections(CORE_SECTIONS);
const finish = getSections([FINISH_SECTION])[0];

const domains = REAL_WORLD_DOMAINS.map((domain) => ({
  ...domain,
  paths: PATHS.filter((path) => path.domainIds.includes(domain.id)),
}));

const description =
  'Detailed RedSec learning path flow chart across web security, cloud compute, enterprise identity, blue team, red team, CTF, binary exploitation, forensics, and reporting.';
---

<BaseLayout title="Learning Paths" description={description}>
  <section class="paths-hero">
    <div class="container">
      <span class="eyebrow">Learning paths</span>
      <h1>Start at the top, then move down into real-world security work.</h1>
      <p class="lead">
        The roadmap uses a top-to-bottom flow: foundation first, shared core
        next, then real-world domains and role-specific milestones.
      </p>
      <div class="path-actions">
        <a class="btn btn-primary" href="#flow">View roadmap</a>
        <a class="btn" href="#role-flows">View role paths</a>
        <a class="btn" href={withBase('/path-guide')}>What the paths mean</a>
      </div>
    </div>
  </section>

  <section id="flow" class="section">
    <div class="container">
      <div class="section-heading">
        <span class="eyebrow">Top-down roadmap</span>
        <h2>Shared starting flow</h2>
        <p>
          Everyone starts with the same base. From there, the roadmap branches
          into domains like web, cloud compute, identity, detection, low-level
          systems, and research workflow.
        </p>
      </div>

      <div class="roadmap-frame shared-roadmap" aria-label="Shared top-to-bottom learning roadmap">
        <a class="roadmap-node roadmap-node-wide roadmap-node-start" href={withBase(sectionHref(start.slug))}>
          <span class="node-art mono">{start.icon}</span>
          <span class="node-body">
            <span class="node-kicker mono">start</span>
            <strong>{start.title}</strong>
            <small>{start.summary}</small>
          </span>
        </a>

        <span class="roadmap-spine" aria-hidden="true"></span>

        <div class="roadmap-group">
          <span class="group-label mono">shared core</span>
          <div class="node-grid">
            {
              core.map((section) => (
                <a class="roadmap-node roadmap-node-small" href={withBase(sectionHref(section.slug))}>
                  <span class="node-art mono">{section.icon}</span>
                  <span class="node-body">
                    <strong>{section.title}</strong>
                    <small>{section.summary}</small>
                  </span>
                </a>
              ))
            }
          </div>
        </div>

        <span class="roadmap-spine" aria-hidden="true"></span>

        <div class="roadmap-node roadmap-node-wide roadmap-node-branch">
          <span class="node-art mono">map</span>
          <span class="node-body">
            <span class="node-kicker mono">branch</span>
            <strong>Pick a real-world surface</strong>
            <small>Choose the work you want to practice before picking a role path.</small>
          </span>
        </div>
      </div>
    </div>
  </section>

  <section id="domains" class="section domain-section">
    <div class="container">
      <div class="section-heading">
        <span class="eyebrow">Real-world domains</span>
        <h2>Branch by the kind of system you want to work on.</h2>
        <p>
          These domain nodes separate the library into practical environments:
          applications, cloud compute, identity, detection, low-level systems,
          and reporting-driven research.
        </p>
      </div>

      <div class="roadmap-frame domain-roadmap" aria-label="Real-world domain branches">
        <div class="roadmap-node roadmap-node-wide">
          <span class="node-art mono">root</span>
          <span class="node-body">
            <span class="node-kicker mono">domain split</span>
            <strong>Choose one or more domains</strong>
            <small>Roles overlap, so domain cards show which paths use them.</small>
          </span>
        </div>

        <span class="roadmap-spine" aria-hidden="true"></span>

        <div class="branch-grid">
          {
            domains.map((domain) => (
              <article class="roadmap-node domain-card" id={`domain-${domain.id}`}>
                <span class="node-art mono">{domain.shortTitle}</span>
                <div class="node-body">
                  <span class="node-kicker mono">domain</span>
                  <h3>{domain.title}</h3>
                  <p>{domain.summary}</p>
                  <div class="example-pills">
                    {domain.examples.map((example) => (
                      <span>{example}</span>
                    ))}
                  </div>
                  <div class="section-pills">
                    {getSections(domain.sections).map((section) => (
                      <a href={withBase(sectionHref(section.slug))}>{section.title}</a>
                    ))}
                  </div>
                  <div class="used-by">
                    <span class="mini-label mono">used by</span>
                    <div>
                      {domain.paths.map((path) => (
                        <a href={`#${path.id}`}>{path.shortTitle}</a>
                      ))}
                    </div>
                  </div>
                </div>
              </article>
            ))
          }
        </div>
      </div>
    </div>
  </section>

  <section id="role-flows" class="section">
    <div class="container">
      <div class="section-heading">
        <span class="eyebrow">Role paths</span>
        <h2>Follow each path from top to bottom.</h2>
        <p>
          Every role starts with the same base, drops into relevant domains,
          moves through ordered milestones, and finishes with reporting and
          career-ready output.
        </p>
      </div>

      <div class="role-flows">
        {
          PATHS.map((path) => (
            <article class="role-roadmap" id={path.id}>
              <header class="role-head">
                <div>
                  <span class="path-id mono">{path.shortTitle}</span>
                  <h3>{path.title}</h3>
                </div>
                <a class="path-guide-link mono" href={withBase(`/path-guide#${path.id}`)}>
                  guide
                </a>
              </header>
              <p class="role-summary">{path.summary}</p>

              <div class="roadmap-frame role-frame" aria-label={`${path.title} top-to-bottom roadmap`}>
                <a class="roadmap-node roadmap-node-wide roadmap-node-start" href={withBase(sectionHref(start.slug))}>
                  <span class="node-art mono">{start.icon}</span>
                  <span class="node-body">
                    <span class="node-kicker mono">01 start</span>
                    <strong>{start.title}</strong>
                    <small>{start.summary}</small>
                  </span>
                </a>

                <span class="roadmap-spine" aria-hidden="true"></span>

                <div class="roadmap-group">
                  <span class="group-label mono">02 core</span>
                  <div class="node-grid compact-grid">
                    {core.map((section) => (
                      <a class="roadmap-node roadmap-node-small" href={withBase(sectionHref(section.slug))}>
                        <span class="node-art mono">{section.icon}</span>
                        <span class="node-body">
                          <strong>{section.title}</strong>
                          <small>{section.summary}</small>
                        </span>
                      </a>
                    ))}
                  </div>
                </div>

                <span class="roadmap-spine" aria-hidden="true"></span>

                <div class="roadmap-group domain-group">
                  <span class="group-label mono">03 domains</span>
                  <div class="branch-grid compact-branches">
                    {getDomains(path.domainIds).map((domain) => (
                      <a class="roadmap-node branch-node" href={`#domain-${domain.id}`}>
                        <span class="node-art mono">{domain.shortTitle}</span>
                        <span class="node-body">
                          <strong>{domain.title}</strong>
                          <small>{domain.summary}</small>
                        </span>
                      </a>
                    ))}
                  </div>
                </div>

                <span class="roadmap-spine" aria-hidden="true"></span>

                <ol class="milestone-roadmap" aria-label={`${path.title} milestone sequence`}>
                  {path.milestones.map((milestone, index) => (
                    <li>
                      <div class="roadmap-node milestone-node">
                        <span class="node-art mono">
                          {String(index + 1).padStart(2, '0')}
                        </span>
                        <div class="node-body">
                          <span class="node-kicker mono">milestone</span>
                          <strong>{milestone.label}</strong>
                          <p>{milestone.note}</p>
                          <div class="section-pills">
                            {getSections(milestone.sections).map((section) => (
                              <a href={withBase(sectionHref(section.slug))}>{section.title}</a>
                            ))}
                          </div>
                        </div>
                      </div>
                    </li>
                  ))}
                </ol>

                <span class="roadmap-spine" aria-hidden="true"></span>

                <a class="roadmap-node roadmap-node-wide roadmap-node-finish" href={withBase(sectionHref(finish.slug))}>
                  <span class="node-art mono">end</span>
                  <span class="node-body">
                    <span class="node-kicker mono">finish</span>
                    <strong>{finish.title}</strong>
                    <small>Turn practice into notes, writeups, reports, interviews, and next steps.</small>
                  </span>
                </a>
              </div>
            </article>
          ))
        }
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .paths-hero {
    padding-block: var(--space-24) var(--space-12);
    border-bottom: var(--hairline);
  }
  .paths-hero h1 {
    max-width: 58rem;
  }
  .path-actions {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-3);
    margin-top: var(--space-8);
  }
  .section-heading {
    max-width: 58rem;
    margin-bottom: var(--space-8);
  }
  .section-heading h2 {
    margin-top: var(--space-2);
  }
  .domain-section {
    border-block: var(--hairline);
  }

  .roadmap-frame {
    --connector: color-mix(in srgb, var(--red-hover) 62%, var(--border));
    display: grid;
    justify-items: center;
    width: 100%;
  }
  .roadmap-node {
    display: grid;
    grid-template-columns: 5rem minmax(0, 1fr);
    width: min(100%, 42rem);
    min-height: 4.75rem;
    overflow: hidden;
    border: var(--line);
    border-radius: var(--radius);
    background: color-mix(in srgb, var(--surface) 88%, var(--bg));
    color: var(--text);
  }
  .roadmap-node:hover {
    border-color: color-mix(in srgb, var(--red-hover) 45%, var(--border));
    text-decoration: none;
  }
  .roadmap-node-wide {
    width: min(100%, 44rem);
  }
  .roadmap-node-small,
  .branch-node {
    width: 100%;
    min-height: 4.25rem;
  }
  .roadmap-node-start,
  .roadmap-node-finish {
    border-color: color-mix(in srgb, var(--red) 55%, var(--border));
  }
  .roadmap-node-branch {
    background: var(--surface);
  }
  .node-art {
    display: grid;
    place-items: center;
    min-height: 100%;
    padding: var(--space-3);
    border-right: var(--hairline);
    background: color-mix(in srgb, var(--red-deep) 72%, var(--elevated));
    color: var(--text);
    font-size: 0.72rem;
    line-height: 1.1;
    text-align: center;
  }
  .node-body {
    display: grid;
    align-content: center;
    gap: 0.3rem;
    min-width: 0;
    padding: var(--space-4);
  }
  .node-kicker,
  .group-label,
  .path-id,
  .path-guide-link,
  .mini-label {
    color: var(--text-muted);
    font-size: 0.74rem;
  }
  .node-body strong,
  .node-body h3 {
    color: var(--text);
    font-size: 1rem;
    line-height: 1.3;
    margin: 0;
  }
  .node-body small,
  .node-body p,
  .role-summary {
    color: var(--text-secondary);
  }
  .node-body small {
    font-size: 0.82rem;
    line-height: 1.45;
  }
  .node-body p {
    margin: 0;
    font-size: 0.9rem;
  }
  .roadmap-spine {
    display: block;
    width: 1px;
    height: 2.25rem;
    background: var(--connector);
    position: relative;
  }
  .roadmap-spine::after {
    content: '';
    position: absolute;
    left: 50%;
    bottom: -0.25rem;
    width: 0.55rem;
    height: 0.55rem;
    border-right: 1px solid var(--connector);
    border-bottom: 1px solid var(--connector);
    transform: translateX(-50%) rotate(45deg);
    background: var(--bg);
  }
  .roadmap-group {
    width: min(100%, 54rem);
    border: 1px dashed color-mix(in srgb, var(--red-hover) 52%, var(--border));
    border-radius: var(--radius);
    padding: var(--space-8) var(--space-4) var(--space-4);
    position: relative;
    background: color-mix(in srgb, var(--surface) 50%, transparent);
  }
  .group-label {
    position: absolute;
    top: var(--space-3);
    left: var(--space-4);
  }
  .node-grid,
  .branch-grid {
    display: grid;
    gap: var(--space-3);
    width: 100%;
  }
  .domain-roadmap .branch-grid {
    width: min(100%, 62rem);
  }
  .domain-card {
    width: 100%;
  }
  .domain-card .node-body {
    align-content: start;
  }
  .example-pills,
  .section-pills,
  .used-by div {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
  }
  .example-pills span,
  .section-pills a,
  .used-by a {
    border: var(--hairline);
    border-radius: var(--radius);
    color: var(--text-secondary);
    font-family: var(--font-mono);
    font-size: 0.72rem;
    line-height: 1.35;
    padding: 0.24rem 0.5rem;
  }
  .section-pills a:hover,
  .used-by a:hover {
    color: var(--text);
    background: var(--elevated);
    text-decoration: none;
  }
  .used-by {
    display: grid;
    gap: var(--space-2);
    border-top: var(--hairline);
    padding-top: var(--space-3);
    margin-top: var(--space-2);
  }
  .role-flows {
    display: grid;
    gap: var(--space-12);
  }
  .role-roadmap {
    border-top: var(--line);
    padding-top: var(--space-8);
  }
  .role-head {
    display: flex;
    justify-content: space-between;
    gap: var(--space-4);
    margin-bottom: var(--space-3);
  }
  .role-head h3 {
    margin: var(--space-1) 0 0;
    font-size: 1.35rem;
  }
  .path-guide-link {
    align-self: start;
    color: var(--red-hover);
  }
  .role-summary {
    max-width: 54rem;
    margin-bottom: var(--space-6);
  }
  .role-frame {
    align-items: start;
  }
  .domain-group {
    width: min(100%, 58rem);
  }
  .milestone-roadmap {
    display: grid;
    justify-items: center;
    width: min(100%, 48rem);
    list-style: none;
    margin: 0;
    padding: 0;
  }
  .milestone-roadmap li {
    display: grid;
    justify-items: center;
    width: 100%;
    margin: 0;
  }
  .milestone-roadmap li + li::before {
    content: '';
    width: 1px;
    height: 1.5rem;
    background: var(--connector);
  }
  .milestone-node {
    width: 100%;
  }

  @media (min-width: 720px) {
    .node-grid,
    .branch-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
    .compact-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
    .compact-branches {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (min-width: 1100px) {
    .domain-roadmap .branch-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 620px) {
    .roadmap-node {
      grid-template-columns: 4rem minmax(0, 1fr);
    }
    .node-art {
      padding: var(--space-2);
      font-size: 0.66rem;
    }
    .node-body {
      padding: var(--space-3);
    }
    .roadmap-group {
      padding-inline: var(--space-3);
    }
    .role-head {
      display: grid;
    }
  }
</style>
