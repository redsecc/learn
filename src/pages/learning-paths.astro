---
import RoadmapThumb from '../components/RoadmapThumb.astro';
import BaseLayout from '../layouts/BaseLayout.astro';
import { withBase } from '../lib/base';
import {
  CORE_SECTIONS,
  FINISH_SECTION,
  PATHS,
  REAL_WORLD_DOMAINS,
  START_SECTION,
  getDomains,
  getSections,
  sectionHref,
} from '../lib/paths';

const sectionVariants: Record<string, string> = {
  [START_SECTION]: 'start',
  foundations: 'defense',
  'tooling-workflows': 'terminal',
  linux: 'terminal',
  networking: 'network',
};

const domainVariants: Record<string, string> = {
  'web-applications': 'web',
  'cloud-compute': 'cloud',
  'enterprise-identity': 'identity',
  'detection-response': 'detect',
  'low-level-systems': 'systems',
  'research-reporting': 'research',
};

const pathVariants: Record<string, string> = {
  'red-teamer': 'offense',
  pentester: 'web',
  'blue-teamer': 'detect',
  'defensive-engineer': 'defense',
  'bug-bounty-hunter': 'research',
  'appsec-specialist': 'app',
  'ctf-player': 'ctf',
  'binary-reverser': 'systems',
  'cloud-container-security': 'cloud',
  'forensics-incident-response': 'detect',
};

const start = getSections([START_SECTION])[0];
const core = getSections(CORE_SECTIONS);
const finish = getSections([FINISH_SECTION])[0];

const domains = REAL_WORLD_DOMAINS.map((domain) => ({
  ...domain,
  variant: domainVariants[domain.id] ?? 'default',
  paths: PATHS.filter((path) => path.domainIds.includes(domain.id)),
}));

const roleCards = PATHS.map((path) => ({
  ...path,
  domains: getDomains(path.domainIds),
  milestoneLabels: path.milestones.map((milestone) => milestone.label),
  variant: pathVariants[path.id] ?? 'default',
}));

const description =
  'Compact RedSec learning path roadmap across web security, cloud compute, identity, blue team, red team, CTF, binary exploitation, forensics, and reporting.';
---

<BaseLayout title="Learning Paths" description={description}>
  <section class="paths-hero">
    <div class="container">
      <span class="eyebrow">Learning paths</span>
      <h1>Pick a path without scrolling through a giant chart.</h1>
      <p class="lead">
        Start with the shared base, choose the real-world systems you care
        about, then follow the compact role path that matches your goal.
      </p>
      <div class="path-actions">
        <a class="btn btn-primary" href="#overview">View overview</a>
        <a class="btn" href="#roles">Choose a role</a>
        <a class="btn" href={withBase('/path-guide')}>Path details</a>
      </div>
    </div>
  </section>

  <section id="overview" class="section">
    <div class="container">
      <div class="section-heading">
        <span class="eyebrow">Short roadmap</span>
        <h2>One top-to-bottom overview.</h2>
        <p>
          The full details live in the path guide. This page keeps the roadmap
          short: foundation, core skills, domains, then a role.
        </p>
      </div>

      <div class="overview-roadmap" aria-label="Compact top-to-bottom learning roadmap">
        <a class="roadmap-node start-node" href={withBase(sectionHref(start.slug))}>
          <RoadmapThumb label={start.title} variant={sectionVariants[start.slug]} />
          <span class="node-copy">
            <span class="node-kicker mono">start</span>
            <strong>{start.title}</strong>
            <small>{start.summary}</small>
          </span>
        </a>

        <span class="roadmap-spine" aria-hidden="true"></span>

        <div class="roadmap-group">
          <span class="group-label mono">core</span>
          <div class="core-grid">
            {
              core.map((section) => (
                <a class="mini-node" href={withBase(sectionHref(section.slug))}>
                  <RoadmapThumb label={section.title} variant={sectionVariants[section.slug] ?? 'default'} />
                  <span>
                    <strong>{section.title}</strong>
                    <small>{section.summary}</small>
                  </span>
                </a>
              ))
            }
          </div>
        </div>

        <span class="roadmap-spine" aria-hidden="true"></span>

        <div class="roadmap-group domain-group">
          <span class="group-label mono">domains</span>
          <div class="domain-grid">
            {
              domains.map((domain) => (
                <article class="domain-node" id={`domain-${domain.id}`}>
                  <RoadmapThumb label={domain.title} variant={domain.variant} />
                  <div>
                    <h3>{domain.title}</h3>
                    <p>{domain.summary}</p>
                    <div class="section-pills">
                      {getSections(domain.sections).slice(0, 4).map((section) => (
                        <a href={withBase(sectionHref(section.slug))}>{section.title}</a>
                      ))}
                    </div>
                  </div>
                </article>
              ))
            }
          </div>
        </div>

        <span class="roadmap-spine" aria-hidden="true"></span>

        <div class="roadmap-node finish-node">
          <RoadmapThumb label={finish.title} variant="research" />
          <span class="node-copy">
            <span class="node-kicker mono">finish</span>
            <strong>Choose a role path</strong>
            <small>Use the compact cards below, then open the guide for deeper detail.</small>
          </span>
        </div>
      </div>
    </div>
  </section>

  <section id="roles" class="section role-section">
    <div class="container">
      <div class="section-heading">
        <span class="eyebrow">Role paths</span>
        <h2>Compact paths you can scan quickly.</h2>
        <p>
          Each card shows the role, the real-world domains it uses, and the
          ordered milestone names without repeating the full foundation chart.
        </p>
      </div>

      <div class="role-grid">
        {
          roleCards.map((path) => (
            <article class="role-card" id={path.id}>
              <header class="role-card-head">
                <RoadmapThumb label={path.shortTitle} variant={path.variant} />
                <div>
                  <span class="path-id mono">{path.shortTitle}</span>
                  <h3>{path.title}</h3>
                  <p>{path.summary}</p>
                </div>
              </header>

              <div class="role-domain-row">
                {path.domains.slice(0, 4).map((domain) => (
                  <a href={`#domain-${domain.id}`}>{domain.shortTitle}</a>
                ))}
              </div>

              <ol class="compact-steps">
                <li>Start with foundation and core skills</li>
                {path.milestoneLabels.slice(0, 3).map((label) => (
                  <li>{label}</li>
                ))}
                <li>{finish.title}</li>
              </ol>

              <a class="guide-link mono" href={withBase(`/path-guide#${path.id}`)}>
                open detailed guide
              </a>
            </article>
          ))
        }
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .paths-hero {
    padding-block: var(--space-24) var(--space-12);
    border-bottom: var(--hairline);
  }
  .paths-hero h1 {
    max-width: 58rem;
  }
  .path-actions {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-3);
    margin-top: var(--space-8);
  }
  .section-heading {
    max-width: 58rem;
    margin-bottom: var(--space-8);
  }
  .section-heading h2 {
    margin-top: var(--space-2);
  }
  .role-section {
    border-top: var(--hairline);
  }

  .overview-roadmap {
    --connector: color-mix(in srgb, var(--red-hover) 62%, var(--border));
    display: grid;
    justify-items: center;
  }
  .roadmap-node,
  .mini-node,
  .domain-node,
  .role-card {
    border: var(--line);
    border-radius: var(--radius);
    background: color-mix(in srgb, var(--surface) 90%, var(--bg));
  }
  .roadmap-node,
  .mini-node,
  .domain-node {
    display: grid;
    grid-template-columns: 5rem minmax(0, 1fr);
    overflow: hidden;
    color: var(--text);
  }
  .roadmap-node {
    width: min(100%, 42rem);
  }
  .mini-node,
  .domain-node {
    min-width: 0;
  }
  .roadmap-node:hover,
  .mini-node:hover {
    border-color: color-mix(in srgb, var(--red-hover) 45%, var(--border));
    text-decoration: none;
  }
  .node-copy,
  .mini-node > span,
  .domain-node > div {
    display: grid;
    align-content: center;
    gap: 0.3rem;
    min-width: 0;
    padding: var(--space-4);
  }
  .node-kicker,
  .group-label,
  .path-id,
  .guide-link {
    color: var(--text-muted);
    font-size: 0.74rem;
  }
  .node-copy strong,
  .mini-node strong,
  .domain-node h3,
  .role-card h3 {
    color: var(--text);
    font-size: 1rem;
    line-height: 1.3;
    margin: 0;
  }
  .node-copy small,
  .mini-node small,
  .domain-node p,
  .role-card p {
    color: var(--text-secondary);
  }
  .node-copy small,
  .mini-node small {
    font-size: 0.82rem;
    line-height: 1.45;
  }
  .domain-node p,
  .role-card p {
    margin: 0;
    font-size: 0.9rem;
  }
  .roadmap-spine {
    display: block;
    width: 1px;
    height: 2rem;
    background: var(--connector);
    position: relative;
  }
  .roadmap-spine::after {
    content: '';
    position: absolute;
    left: 50%;
    bottom: -0.25rem;
    width: 0.55rem;
    height: 0.55rem;
    border-right: 1px solid var(--connector);
    border-bottom: 1px solid var(--connector);
    transform: translateX(-50%) rotate(45deg);
    background: var(--bg);
  }
  .roadmap-group {
    width: min(100%, 58rem);
    border: 1px dashed color-mix(in srgb, var(--red-hover) 52%, var(--border));
    border-radius: var(--radius);
    padding: var(--space-8) var(--space-4) var(--space-4);
    position: relative;
    background: color-mix(in srgb, var(--surface) 44%, transparent);
  }
  .group-label {
    position: absolute;
    top: var(--space-3);
    left: var(--space-4);
  }
  .core-grid,
  .domain-grid,
  .role-grid {
    display: grid;
    gap: var(--space-4);
  }
  .domain-grid {
    align-items: stretch;
  }
  .section-pills,
  .role-domain-row {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
  }
  .section-pills a,
  .role-domain-row a {
    border: var(--hairline);
    border-radius: var(--radius);
    color: var(--text-secondary);
    font-family: var(--font-mono);
    font-size: 0.72rem;
    line-height: 1.35;
    padding: 0.24rem 0.5rem;
  }
  .section-pills a:hover,
  .role-domain-row a:hover {
    color: var(--text);
    background: var(--elevated);
    text-decoration: none;
  }

  .role-grid {
    grid-template-columns: 1fr;
  }
  .role-card {
    display: grid;
    gap: var(--space-4);
    padding: var(--space-4);
  }
  .role-card-head {
    display: grid;
    grid-template-columns: 5rem minmax(0, 1fr);
    gap: var(--space-4);
    align-items: stretch;
  }
  .role-card-head :global(.roadmap-thumb) {
    border-radius: var(--radius);
    min-height: 5rem;
  }
  .role-card h3 {
    margin-top: var(--space-1);
  }
  .compact-steps {
    display: grid;
    gap: var(--space-2);
    list-style: none;
    margin: 0;
    padding: var(--space-4) 0 0;
    border-top: var(--hairline);
    color: var(--text-secondary);
    font-size: 0.88rem;
  }
  .compact-steps li {
    margin: 0;
    display: grid;
    grid-template-columns: 0.7rem minmax(0, 1fr);
    gap: var(--space-2);
  }
  .compact-steps li::before {
    content: '';
    width: 0.45rem;
    height: 0.45rem;
    margin-top: 0.62rem;
    border-radius: 999px;
    background: color-mix(in srgb, var(--red-hover) 70%, var(--border));
  }
  .guide-link {
    color: var(--red-hover);
    justify-self: start;
  }

  @media (min-width: 760px) {
    .core-grid,
    .domain-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
    .role-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 620px) {
    .roadmap-node,
    .mini-node,
    .domain-node,
    .role-card-head {
      grid-template-columns: 4rem minmax(0, 1fr);
    }
    .node-copy,
    .mini-node > span,
    .domain-node > div {
      padding: var(--space-3);
    }
    .roadmap-group {
      padding-inline: var(--space-3);
    }
  }
</style>
