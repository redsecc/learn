---
import RoadmapThumb from '../components/RoadmapThumb.astro';
import BaseLayout from '../layouts/BaseLayout.astro';
import { withBase } from '../lib/base';
import {
  CORE_SECTIONS,
  FINISH_SECTION,
  PATHS,
  START_SECTION,
  getDomains,
  getSections,
  sectionHref,
} from '../lib/paths';

const sectionVariants: Record<string, string> = {
  [START_SECTION]: 'start',
  foundations: 'defense',
  'tooling-workflows': 'terminal',
  linux: 'terminal',
  networking: 'network',
};

const pathVariants: Record<string, string> = {
  'red-teamer': 'offense',
  pentester: 'web',
  'blue-teamer': 'detect',
  'defensive-engineer': 'defense',
  'bug-bounty-hunter': 'research',
  'appsec-specialist': 'app',
  'ctf-player': 'ctf',
  'binary-reverser': 'systems',
  'cloud-container-security': 'cloud',
  'forensics-incident-response': 'detect',
};

const start = getSections([START_SECTION])[0];
const core = getSections(CORE_SECTIONS);
const finish = getSections([FINISH_SECTION])[0];

const rolePaths = PATHS.map((path) => ({
  ...path,
  domains: getDomains(path.domainIds).slice(0, 3),
  variant: pathVariants[path.id] ?? 'default',
}));

const description =
  'A single compact RedSec learning paths flowchart for red team, pentest, blue team, AppSec, CTF, binary exploitation, cloud, and forensics learners.';
---

<BaseLayout title="Learning Paths" description={description}>
  <section class="paths-hero">
    <div class="container">
      <span class="eyebrow">Learning paths</span>
      <h1>One small flowchart for every path.</h1>
      <p class="lead">
        Start with the same foundation, build the shared core skills, then pick
        the path that matches the work you want to do.
      </p>
      <div class="path-actions">
        <a class="btn btn-primary" href="#flowchart">View flowchart</a>
        <a class="btn" href={withBase('/path-guide')}>Read path guide</a>
      </div>
    </div>
  </section>

  <section id="flowchart" class="section">
    <div class="container">
      <div class="section-heading">
        <span class="eyebrow">Single roadmap</span>
        <h2>Start once, then branch into a role.</h2>
        <p>
          This keeps the page simple: one chart, one branch point, and a clear
          list of path options.
        </p>
      </div>

      <div class="path-flow" aria-label="Single RedSec learning paths flowchart">
        <a class="flow-node flow-node-main" href={withBase(sectionHref(start.slug))}>
          <RoadmapThumb label={start.title} variant={sectionVariants[start.slug]} />
          <span class="node-copy">
            <span class="node-kicker mono">01 start</span>
            <strong>{start.title}</strong>
            <small>{start.summary}</small>
          </span>
        </a>

        <span class="flow-line" aria-hidden="true"></span>

        <div class="flow-node flow-node-main core-node">
          <RoadmapThumb label="Core skills" variant="terminal" />
          <div class="node-copy">
            <span class="node-kicker mono">02 core</span>
            <strong>Build the shared base</strong>
            <small>Everyone needs the same practical base before specializing.</small>
            <div class="core-links">
              {
                core.map((section) => (
                  <a href={withBase(sectionHref(section.slug))}>
                    <RoadmapThumb label={section.title} variant={sectionVariants[section.slug] ?? 'default'} />
                    <span>{section.title}</span>
                  </a>
                ))
              }
            </div>
          </div>
        </div>

        <span class="flow-line flow-line-split" aria-hidden="true"></span>

        <div class="split-label">
          <span class="mono">03 choose path</span>
        </div>

        <div class="role-branch-grid">
          {
            rolePaths.map((path) => (
              <a class="role-node" href={withBase(`/path-guide#${path.id}`)} id={path.id}>
                <RoadmapThumb label={path.shortTitle} variant={path.variant} />
                <span class="role-copy">
                  <span class="path-id mono">{path.shortTitle}</span>
                  <strong>{path.title}</strong>
                  <small>{path.role}</small>
                  <span class="domain-row" aria-label={`${path.title} focus areas`}>
                    {path.domains.map((domain) => (
                      <span>{domain.shortTitle}</span>
                    ))}
                  </span>
                </span>
              </a>
            ))
          }
        </div>

        <span class="flow-line" aria-hidden="true"></span>

        <a class="flow-node flow-node-main finish-node" href={withBase(sectionHref(finish.slug))}>
          <RoadmapThumb label={finish.title} variant="research" />
          <span class="node-copy">
            <span class="node-kicker mono">04 finish</span>
            <strong>{finish.title}</strong>
            <small>Turn labs, notes, findings, and projects into clear proof of skill.</small>
          </span>
        </a>
      </div>

      <div class="guide-strip">
        <p>
          Need the deeper breakdown for a path? The detailed guide explains
          each role, who it is for, and what to learn next.
        </p>
        <a class="btn" href={withBase('/path-guide')}>Open path guide</a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .paths-hero {
    padding-block: var(--space-24) var(--space-12);
    border-bottom: var(--hairline);
  }
  .paths-hero h1 {
    max-width: 58rem;
  }
  .path-actions {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-3);
    margin-top: var(--space-8);
  }
  .section-heading {
    max-width: 58rem;
    margin-bottom: var(--space-8);
  }
  .section-heading h2 {
    margin-top: var(--space-2);
  }

  .path-flow {
    --connector: color-mix(in srgb, var(--red-hover) 62%, var(--border));
    display: grid;
    justify-items: center;
  }
  .flow-node,
  .role-node {
    border: var(--line);
    border-radius: var(--radius);
    background: color-mix(in srgb, var(--surface) 90%, var(--bg));
    color: var(--text);
  }
  .flow-node-main,
  .role-node {
    display: grid;
    grid-template-columns: 5rem minmax(0, 1fr);
    overflow: hidden;
  }
  .flow-node-main {
    width: min(100%, 42rem);
  }
  .flow-node-main:hover,
  .role-node:hover,
  .core-links a:hover {
    border-color: color-mix(in srgb, var(--red-hover) 45%, var(--border));
    text-decoration: none;
  }
  .node-copy,
  .role-copy {
    display: grid;
    align-content: center;
    gap: 0.35rem;
    min-width: 0;
    padding: var(--space-4);
  }
  .node-kicker,
  .path-id,
  .split-label,
  .domain-row {
    color: var(--text-muted);
    font-size: 0.74rem;
  }
  .node-copy strong,
  .role-copy strong {
    color: var(--text);
    font-size: 1rem;
    line-height: 1.3;
  }
  .node-copy small,
  .role-copy small,
  .guide-strip p {
    color: var(--text-secondary);
  }
  .node-copy small,
  .role-copy small {
    font-size: 0.84rem;
    line-height: 1.45;
  }

  .flow-line {
    display: block;
    width: 1px;
    height: 1.8rem;
    background: var(--connector);
    position: relative;
  }
  .flow-line::after {
    content: '';
    position: absolute;
    left: 50%;
    bottom: -0.25rem;
    width: 0.55rem;
    height: 0.55rem;
    border-right: 1px solid var(--connector);
    border-bottom: 1px solid var(--connector);
    transform: translateX(-50%) rotate(45deg);
    background: var(--bg);
  }
  .flow-line-split {
    height: 1.5rem;
  }
  .split-label {
    border: var(--hairline);
    border-radius: var(--radius);
    background: var(--surface);
    padding: 0.35rem 0.7rem;
    margin-bottom: var(--space-4);
  }

  .core-node {
    align-items: stretch;
  }
  .core-links {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: var(--space-2);
    margin-top: var(--space-2);
  }
  .core-links a {
    display: grid;
    grid-template-columns: 2.75rem minmax(0, 1fr);
    align-items: center;
    overflow: hidden;
    border: var(--hairline);
    border-radius: var(--radius);
    color: var(--text-secondary);
    font-size: 0.78rem;
    line-height: 1.25;
  }
  .core-links :global(.roadmap-thumb) {
    width: 2.75rem;
  }
  .core-links :global(.roadmap-thumb svg) {
    min-height: 2.75rem;
  }
  .core-links span {
    padding: 0.35rem 0.5rem;
  }

  .role-branch-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: var(--space-3);
    width: min(100%, 58rem);
    padding: var(--space-4);
    border: 1px dashed color-mix(in srgb, var(--red-hover) 52%, var(--border));
    border-radius: var(--radius);
    background: color-mix(in srgb, var(--surface) 44%, transparent);
  }
  .role-node {
    min-width: 0;
  }
  .role-node :global(.roadmap-thumb) {
    min-height: 100%;
  }
  .role-copy {
    padding: var(--space-3);
  }
  .domain-row {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
    margin-top: var(--space-1);
  }
  .domain-row span {
    border: var(--hairline);
    border-radius: var(--radius);
    color: var(--text-secondary);
    font-family: var(--font-mono);
    font-size: 0.68rem;
    line-height: 1.3;
    padding: 0.2rem 0.42rem;
  }

  .guide-strip {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-4);
    margin-top: var(--space-8);
    padding-top: var(--space-6);
    border-top: var(--hairline);
  }
  .guide-strip p {
    max-width: 44rem;
    margin: 0;
  }

  @media (min-width: 1040px) {
    .role-branch-grid {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }
  }

  @media (max-width: 720px) {
    .flow-node-main,
    .role-node {
      grid-template-columns: 4rem minmax(0, 1fr);
    }
    .node-copy,
    .role-copy {
      padding: var(--space-3);
    }
    .role-branch-grid,
    .core-links {
      grid-template-columns: 1fr;
    }
    .role-branch-grid {
      padding: var(--space-3);
    }
  }
</style>
