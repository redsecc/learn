---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import TableOfContents from '../../components/TableOfContents.astro';
import ProgressTracker from '../../components/ProgressTracker.astro';
import Callout from '../../components/Callout.astro';
import { withBase } from '../../lib/base';
import { abs, breadcrumb, ORG_REF, SITE_REF } from '../../lib/seo';

export async function getStaticPaths() {
  const lessons = await getCollection('lessons');
  const paths = await getCollection('paths');

  return lessons.map((lesson) => {
    const siblings = lessons
      .filter((l) => l.data.path === lesson.data.path)
      .sort((a, b) => a.data.order - b.data.order);
    const idx = siblings.findIndex((l) => l.id === lesson.id);
    const path = paths.find((p) => p.data.slug === lesson.data.path);
    return {
      params: { slug: lesson.id },
      props: {
        lesson,
        path,
        prev: idx > 0 ? siblings[idx - 1] : null,
        next: idx < siblings.length - 1 ? siblings[idx + 1] : null,
      },
    };
  });
}

const { lesson, path, prev, next } = Astro.props;
const { Content, headings } = await render(lesson);

const jsonLd = [
  {
    '@type': 'TechArticle',
    headline: lesson.data.title,
    description: lesson.data.summary,
    url: abs(`/lessons/${lesson.id}`),
    keywords: lesson.data.tags.join(', '),
    articleSection: path?.data.title,
    proficiencyLevel: lesson.data.difficulty,
    inLanguage: 'en',
    author: ORG_REF,
    publisher: ORG_REF,
    isPartOf: SITE_REF,
  },
  breadcrumb([
    { name: 'Paths', path: '/paths' },
    ...(path ? [{ name: path.data.title, path: `/paths/${path.data.slug}` }] : []),
    { name: lesson.data.title, path: `/lessons/${lesson.id}` },
  ]),
];
---

<BaseLayout
  title={lesson.data.title}
  description={lesson.data.summary}
  ogType="article"
  keywords={lesson.data.tags}
  jsonLd={jsonLd}
>
  <div class="container lesson-shell">
    <div class="lesson-grid">
      <!-- Left sidebar: table of contents -->
      <aside class="lesson-aside">
        <TableOfContents headings={headings} />
      </aside>

      <!-- Main content -->
      <article class="lesson-main">
        <nav class="crumbs mono" aria-label="Breadcrumb">
          <a href={withBase('/paths')}>paths</a>
          <span aria-hidden="true">/</span>
          {path && <a href={withBase(`/paths/${path.data.slug}`)}>{path.data.slug}</a>}
          <span aria-hidden="true">/</span>
          <span>{lesson.id}</span>
        </nav>

        <header class="lesson-header">
          <div class="lesson-tags">
            <span class="chip" data-difficulty={lesson.data.difficulty}>
              {lesson.data.difficulty}
            </span>
            {lesson.data.tags.map((t) => <span class="chip">{t}</span>)}
          </div>
          <h1>{lesson.data.title}</h1>
          <p class="lead">{lesson.data.summary}</p>
        </header>

        <div class="prose">
          <Content components={{ Callout }} />
        </div>

        <div class="lesson-complete">
          <ProgressTracker slug={lesson.id} />
        </div>

        <nav class="prevnext" aria-label="Lesson navigation">
          {
            prev ? (
              <a class="prevnext-link prev" href={withBase(`/lessons/${prev.id}`)}>
                <span class="pn-dir mono">← Previous</span>
                <span class="pn-title">{prev.data.title}</span>
              </a>
            ) : (
              <span />
            )
          }
          {
            next ? (
              <a class="prevnext-link next" href={withBase(`/lessons/${next.id}`)}>
                <span class="pn-dir mono">Next →</span>
                <span class="pn-title">{next.data.title}</span>
              </a>
            ) : (
              <span />
            )
          }
        </nav>
      </article>
    </div>
  </div>
</BaseLayout>

<style>
  .lesson-shell {
    padding-block: var(--space-12) var(--space-16);
  }
  .lesson-grid {
    display: grid;
    gap: var(--space-12);
  }
  @media (min-width: 900px) {
    .lesson-grid {
      grid-template-columns: 15rem minmax(0, 1fr);
    }
  }
  .lesson-main {
    min-width: 0;
    max-width: var(--maxw-prose);
  }
  .crumbs {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
    font-size: 0.8rem;
    color: var(--text-muted);
    margin-bottom: var(--space-6);
  }
  .crumbs a {
    color: var(--text-secondary);
  }
  .lesson-header {
    margin-bottom: var(--space-8);
  }
  .lesson-tags {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
    margin-bottom: var(--space-4);
  }
  .lesson-header h1 {
    margin-bottom: var(--space-4);
  }

  .lesson-complete {
    margin-top: var(--space-12);
  }

  .prevnext {
    display: grid;
    gap: var(--space-4);
    margin-top: var(--space-8);
  }
  @media (min-width: 560px) {
    .prevnext {
      grid-template-columns: 1fr 1fr;
    }
  }
  .prevnext-link {
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
    padding: var(--space-4);
    background: var(--surface);
    border: var(--hairline);
    border-radius: var(--radius);
    color: var(--text);
  }
  .prevnext-link:hover {
    background: var(--elevated);
    border-color: var(--text-muted);
    text-decoration: none;
  }
  .prevnext-link.next {
    text-align: right;
  }
  .pn-dir {
    font-size: 0.72rem;
    color: var(--text-muted);
  }
  .pn-title {
    color: var(--text);
    font-weight: 500;
  }
  .prevnext-link:hover .pn-dir {
    color: var(--red-hover);
  }
</style>
