---
import BaseLayout from '../layouts/BaseLayout.astro';
import { SITE } from '../lib/site';
import { withBase } from '../lib/base';
import { abs, breadcrumb } from '../lib/seo';

const jsonLd = [
  {
    '@type': 'AboutPage',
    name: 'About RedSec',
    description: 'What RedSec is, who it is for, and how it stays free and open.',
    url: abs('/about'),
  },
  breadcrumb([{ name: 'About', path: '/about' }]),
];
---

<BaseLayout
  title="About"
  description="RedSec is a free, open learning center for red teaming — no accounts, no tracking. Learn what it is, who it's for, and how it stays open."
  jsonLd={jsonLd}
>
  <section class="section">
    <div class="container about">
      <header class="page-head">
        <span class="eyebrow">About</span>
        <h1>Red teaming, in the open.</h1>
        <p class="lead">
          RedSec is a free, open learning center for offensive security. No
          accounts, no paywalls, no tracking — just the techniques, explained
          clearly, one click from any lesson.
        </p>
      </header>

      <div class="prose">
        <h2>Why RedSec exists</h2>
        <p>
          Good offensive-security material is scattered, gated behind logins, or
          buried in walls of theory. RedSec is the opposite: short, practical
          lessons and hands-on labs you can start instantly, written for people
          who learn by doing. We treat the absence of accounts as a feature —
          fewer pages, less friction, nothing tracking you.
        </p>

        <h2>What you'll find</h2>
        <ul>
          <li>
            <strong>Paths</strong> — structured tracks that take you from
            enumeration to exploitation, in order.
          </li>
          <li>
            <strong>Labs</strong> — guided challenges you run yourself, locally,
            on targets you own.
          </li>
          <li>
            <strong>Reference</strong> — fast cheatsheets for when you're
            mid-engagement and just need the command.
          </li>
        </ul>
        <p>
          The full learning platform lives at
          <a href="https://learn.redsec.cc">learn.redsec.cc</a>.
        </p>

        <h2>Free and open</h2>
        <p>
          RedSec sets no cookies, ships no analytics, and makes no third-party
          requests. Any progress you track is stored only on your own device.
          The site is open source — improvements and new lessons are welcome.
        </p>

        <h2>Ethics &amp; authorized use</h2>
        <p>
          Everything here is for <strong>authorized testing and education</strong>.
          The techniques are real and many are illegal to use without
          permission. Only ever apply them to systems you own or have explicit,
          written authorization to test.
        </p>

        <h2>Community</h2>
        <p>Come build it with us:</p>
        <div class="about-links">
          <a class="btn" href={SITE.social.github} target="_blank" rel="noopener noreferrer">
            GitHub ↗
          </a>
          <a class="btn" href={SITE.social.discord} target="_blank" rel="noopener noreferrer">
            Discord ↗
          </a>
          <a class="btn btn-primary" href="https://learn.redsec.cc">Start learning →</a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .about {
    max-width: var(--maxw-prose);
  }
  .page-head {
    margin-bottom: var(--space-8);
  }
  .page-head h1 {
    margin-bottom: var(--space-4);
  }
  .about-links {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-3);
    margin-top: var(--space-6);
  }
</style>
