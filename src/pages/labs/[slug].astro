---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Callout from '../../components/Callout.astro';
import { withBase } from '../../lib/base';

export async function getStaticPaths() {
  const labs = await getCollection('labs');
  const paths = await getCollection('paths');
  return labs.map((lab) => ({
    params: { slug: lab.id },
    props: { lab, path: paths.find((p) => p.data.slug === lab.data.path) ?? null },
  }));
}

const { lab, path } = Astro.props;
const { Content } = await render(lab);
---

<BaseLayout title={lab.data.title} description={lab.data.objective} ogType="article">
  <div class="container lab-shell">
    <article class="lab-main">
      <nav class="crumbs mono" aria-label="Breadcrumb">
        <a href={withBase('/labs')}>labs</a>
        <span aria-hidden="true">/</span>
        <span>{lab.id}</span>
      </nav>

      <header class="lab-header">
        <div class="lab-tags">
          <span class="chip" data-difficulty={lab.data.difficulty}>
            {lab.data.difficulty}
          </span>
          {lab.data.tags.map((t) => <span class="chip">{t}</span>)}
        </div>
        <h1>{lab.data.title}</h1>
      </header>

      <div class="objective-box">
        <p class="obj-label mono">Objective</p>
        <p class="obj-text">{lab.data.objective}</p>
        <div class="obj-links">
          {
            lab.data.targetUrl && (
              <a
                class="btn btn-primary"
                href={lab.data.targetUrl}
                target="_blank"
                rel="noopener noreferrer"
              >
                Get the target ↗
              </a>
            )
          }
          {
            path && (
              <a class="btn" href={withBase(`/paths/${path.data.slug}`)}>
                Related path: {path.data.title}
              </a>
            )
          }
        </div>
      </div>

      <div class="prose lab-prose">
        <Content components={{ Callout }} />
      </div>
    </article>
  </div>
</BaseLayout>

<style>
  .lab-shell {
    padding-block: var(--space-12) var(--space-16);
  }
  .lab-main {
    max-width: var(--maxw-prose);
    margin-inline: auto;
  }
  .crumbs {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
    font-size: 0.8rem;
    color: var(--text-muted);
    margin-bottom: var(--space-6);
  }
  .crumbs a {
    color: var(--text-secondary);
  }
  .lab-tags {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
    margin-bottom: var(--space-4);
  }
  .objective-box {
    border: var(--hairline);
    border-left: 2px solid var(--red);
    border-radius: 0 var(--radius) var(--radius) 0;
    background: var(--surface);
    padding: var(--space-4) var(--space-6);
    margin-bottom: var(--space-12);
  }
  .obj-label {
    margin: 0 0 var(--space-2);
    font-size: 0.72rem;
    letter-spacing: 0.06em;
    color: var(--red-hover);
  }
  .obj-text {
    margin: 0 0 var(--space-4);
    color: var(--text);
  }
  .obj-links {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-3);
  }

  /* Collapsible hints + solution (native <details>, no JS) */
  .lab-prose :global(details) {
    border: var(--hairline);
    border-radius: var(--radius);
    background: var(--surface);
    padding: 0 var(--space-4);
    margin: var(--space-3) 0;
  }
  .lab-prose :global(details[open]) {
    padding-bottom: var(--space-4);
    border-color: var(--text-muted);
  }
  .lab-prose :global(summary) {
    cursor: pointer;
    padding: var(--space-3) 0;
    font-family: var(--font-mono);
    font-size: 0.9rem;
    color: var(--text);
    list-style-position: inside;
  }
  .lab-prose :global(summary:hover) {
    color: var(--red-hover);
  }
  .lab-prose :global(details[open] > summary) {
    margin-bottom: var(--space-2);
    border-bottom: var(--hairline);
  }
</style>
