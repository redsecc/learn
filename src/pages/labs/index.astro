---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { withBase } from '../../lib/base';

const labs = (await getCollection('labs')).sort((a, b) =>
  a.data.title.localeCompare(b.data.title)
);
---

<BaseLayout
  title="Labs"
  description="Guided red team challenges. Each lab gives you an objective, local setup, hints, and a full solution — no accounts, no remote infrastructure."
>
  <section class="section">
    <div class="container">
      <header class="page-head">
        <span class="eyebrow">Labs</span>
        <h1>Guided challenges</h1>
        <p class="lead">
          RedSec hosts no infrastructure, so every lab is something you run
          yourself — locally, on a target you own. Each one has an objective,
          setup notes, collapsible hints, and a full solution.
        </p>
      </header>

      <div class="grid grid-2">
        {
          labs.map((lab) => (
            <a class="lab-card" href={withBase(`/labs/${lab.id}`)}>
              <div class="lab-card-top">
                <span class="chip" data-difficulty={lab.data.difficulty}>
                  {lab.data.difficulty}
                </span>
                <span class="mono lab-kind">lab</span>
              </div>
              <h3 class="lab-title">{lab.data.title}</h3>
              <p class="lab-objective">{lab.data.objective}</p>
              <span class="lab-go mono" aria-hidden="true">Open lab →</span>
            </a>
          ))
        }
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .page-head {
    max-width: var(--maxw-prose);
    margin-bottom: var(--space-12);
  }
  .page-head h1 {
    margin-bottom: var(--space-4);
  }
  .lab-card {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    background: var(--surface);
    border: var(--hairline);
    border-radius: var(--radius);
    padding: var(--space-6);
    color: var(--text);
    height: 100%;
    transition: background 0.15s ease, border-color 0.15s ease, transform 0.15s ease;
  }
  .lab-card:hover {
    background: var(--elevated);
    border-color: var(--text-muted);
    text-decoration: none;
    transform: translateY(-2px);
  }
  .lab-card-top {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }
  .lab-kind {
    color: var(--text-muted);
    font-size: 0.75rem;
  }
  .lab-title {
    margin: 0;
    font-size: 1.15rem;
  }
  .lab-objective {
    margin: 0;
    color: var(--text-secondary);
    font-size: 0.95rem;
  }
  .lab-go {
    margin-top: auto;
    padding-top: var(--space-4);
    color: var(--text-secondary);
    font-size: 0.8rem;
    border-top: var(--hairline);
  }
  .lab-card:hover .lab-go {
    color: var(--red-hover);
  }
</style>
