---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import PathCard from '../../components/PathCard.astro';
import { abs, breadcrumb } from '../../lib/seo';

const paths = (await getCollection('paths')).sort((a, b) => a.data.order - b.data.order);
const lessons = await getCollection('lessons');
const countFor = (slug: string) => lessons.filter((l) => l.data.path === slug).length;

const jsonLd = [
  {
    '@type': 'CollectionPage',
    name: 'Learning paths',
    description: 'All RedSec learning paths.',
    url: abs('/paths'),
    hasPart: paths.map((p) => ({
      '@type': 'Course',
      name: p.data.title,
      description: p.data.summary,
      url: abs(`/paths/${p.data.slug}`),
    })),
  },
  breadcrumb([{ name: 'Paths', path: '/paths' }]),
];
---

<BaseLayout
  title="Learning paths"
  description="All RedSec learning paths — structured tracks that take you from enumeration to exploitation, free and without an account."
  jsonLd={jsonLd}
>
  <section class="section">
    <div class="container">
      <header class="page-head">
        <span class="eyebrow">Paths</span>
        <h1>Learning paths</h1>
        <p class="lead">
          Each path is an ordered set of lessons. Work through one top to bottom,
          or jump to whatever you need — your progress is tracked on this device.
        </p>
      </header>

      <div class="grid grid-2">
        {
          paths.map((p) => (
            <PathCard
              title={p.data.title}
              summary={p.data.summary}
              slug={p.data.slug}
              icon={p.data.icon}
              order={p.data.order}
              lessonCount={countFor(p.data.slug)}
            />
          ))
        }
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .page-head {
    max-width: var(--maxw-prose);
    margin-bottom: var(--space-12);
  }
  .page-head h1 {
    margin-bottom: var(--space-4);
  }
</style>
