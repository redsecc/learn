---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import LessonCard from '../../components/LessonCard.astro';
import PathProgress from '../../components/PathProgress.astro';
import { withBase } from '../../lib/base';
import { abs, breadcrumb, ORG_REF } from '../../lib/seo';

export async function getStaticPaths() {
  const paths = await getCollection('paths');
  const lessons = await getCollection('lessons');
  return paths.map((path) => {
    const pathLessons = lessons
      .filter((l) => l.data.path === path.data.slug)
      .sort((a, b) => a.data.order - b.data.order);
    return {
      params: { slug: path.data.slug },
      props: { path, lessons: pathLessons },
    };
  });
}

const { path, lessons } = Astro.props;
const lessonSlugs = lessons.map((l) => l.id);

const jsonLd = [
  {
    '@type': 'Course',
    name: path.data.title,
    description: path.data.summary,
    url: abs(`/paths/${path.data.slug}`),
    provider: ORG_REF,
    inLanguage: 'en',
    hasPart: lessons.map((l) => ({
      '@type': 'LearningResource',
      name: l.data.title,
      url: abs(`/lessons/${l.id}`),
    })),
  },
  breadcrumb([
    { name: 'Paths', path: '/paths' },
    { name: path.data.title, path: `/paths/${path.data.slug}` },
  ]),
];
---

<BaseLayout title={path.data.title} description={path.data.summary} jsonLd={jsonLd}>
  <section class="section">
    <div class="container path-page">
      <nav class="crumbs mono" aria-label="Breadcrumb">
        <a href={withBase('/paths')}>paths</a>
        <span aria-hidden="true">/</span>
        <span>{path.data.slug}</span>
      </nav>

      <header class="page-head">
        <span class="eyebrow">Learning path</span>
        <h1>{path.data.title}</h1>
        <p class="lead">{path.data.summary}</p>
      </header>

      <div class="path-progress-wrap">
        <PathProgress lessons={lessonSlugs} showReset={true} />
      </div>

      <ol class="lesson-list">
        {
          lessons.map((lesson) => (
            <li>
              <LessonCard
                title={lesson.data.title}
                summary={lesson.data.summary}
                slug={lesson.id}
                difficulty={lesson.data.difficulty}
                order={lesson.data.order}
                tags={lesson.data.tags}
              />
            </li>
          ))
        }
      </ol>
    </div>
  </section>
</BaseLayout>

<style>
  .path-page {
    max-width: 60rem;
  }
  .crumbs {
    display: flex;
    gap: var(--space-2);
    font-size: 0.8rem;
    color: var(--text-muted);
    margin-bottom: var(--space-6);
  }
  .crumbs a {
    color: var(--text-secondary);
  }
  .page-head {
    margin-bottom: var(--space-8);
  }
  .page-head h1 {
    margin-bottom: var(--space-4);
  }
  .path-progress-wrap {
    background: var(--surface);
    border: var(--hairline);
    border-radius: var(--radius);
    padding: var(--space-4) var(--space-6);
    margin-bottom: var(--space-8);
  }
  .lesson-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }
</style>
