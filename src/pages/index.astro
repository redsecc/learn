---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getLessonsBySection, pageSlugOf } from '../lib/learn';
import { withBase } from '../lib/base';

const groups = await getLessonsBySection();
const lessonCount = groups.reduce((sum, group) => sum + group.pages.length, 0);
const sectionCount = groups.length;
// First page of each section, for "jump in" links.
const firstPageHref = (slug: string) => {
  const g = groups.find((g) => g.section.slug === slug);
  if (!g || g.pages.length === 0) return withBase(`/${slug}`);
  return withBase(`/${slug}/${pageSlugOf(g.pages[0].id)}`);
};
const start = firstPageHref('getting-started');
---

<BaseLayout
  title="Learn"
  description="The RedSec learning platform — a free, open guide to offensive security: CTFs, bug bounties, and finding vulnerabilities."
>
  <section class="lander">
    <div class="container">
      <span class="eyebrow">Learn · learn.redsec.cc</span>
      <h1 class="lander-title">Start learning at <span class="accent">RedSec</span>.</h1>
      <p class="lead">
        A free, open learning library for offensive security. Work through
        structured tutorials, labs, references, and reporting guides in the
        order that matches your goal.
      </p>
      <dl class="stats" aria-label="Learning library stats">
        <div>
          <dt>{lessonCount}+</dt>
          <dd>lessons</dd>
        </div>
        <div>
          <dt>{sectionCount}</dt>
          <dd>sections</dd>
        </div>
        <div>
          <dt>0</dt>
          <dd>accounts required</dd>
        </div>
      </dl>
      <div class="lander-actions">
        <a class="btn btn-primary" href={start}>Start learning →</a>
        <a class="btn" href="#library">Browse library ↓</a>
      </div>
    </div>
  </section>

  <section id="library" class="section">
    <div class="container">
      <div class="grid grid-2">
        {
          groups.map(({ section, pages }) => (
            <a class="sec-card" href={firstPageHref(section.slug)}>
              <div class="sec-top">
                <span class="sec-icon mono" aria-hidden="true">{section.icon}</span>
                <span class="sec-count mono">
                  {pages.length} {pages.length === 1 ? 'lesson' : 'lessons'}
                </span>
              </div>
              <h2 class="sec-title">{section.title}</h2>
              <p class="sec-summary">{section.summary}</p>
              <span class="sec-go mono" aria-hidden="true">Open →</span>
            </a>
          ))
        }
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .lander {
    padding-block: var(--space-24) var(--space-12);
    border-bottom: var(--hairline);
  }
  .lander-title {
    font-size: 3.5rem;
    margin-bottom: var(--space-6);
  }
  .lander .lead {
    max-width: var(--maxw-prose);
  }
  .stats {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: var(--space-3);
    max-width: 36rem;
    margin: var(--space-8) 0 0;
  }
  .stats div {
    border: var(--hairline);
    background: var(--surface);
    border-radius: var(--radius);
    padding: var(--space-4);
  }
  .stats dt {
    color: var(--text);
    font-size: 1.35rem;
    line-height: 1;
    margin-bottom: var(--space-2);
  }
  .stats dd {
    margin: 0;
    color: var(--text-muted);
    font-family: var(--font-mono);
    font-size: 0.75rem;
  }
  .lander-actions {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-3);
    margin-top: var(--space-8);
  }
  .sec-card {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    background: var(--surface);
    border: var(--hairline);
    border-radius: var(--radius);
    padding: var(--space-6);
    color: var(--text);
    height: 100%;
    transition: background 0.15s ease, border-color 0.15s ease, transform 0.15s ease;
  }
  .sec-card:hover {
    background: var(--elevated);
    border-color: var(--text-muted);
    text-decoration: none;
    transform: translateY(-2px);
  }
  .sec-top {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }
  .sec-icon {
    color: var(--red);
    font-size: 0.82rem;
  }
  .sec-count {
    color: var(--text-muted);
    font-size: 0.8rem;
  }
  .sec-title {
    margin: 0;
    font-size: 1.2rem;
  }
  .sec-summary {
    margin: 0;
    color: var(--text-secondary);
    font-size: 0.95rem;
  }
  .sec-go {
    margin-top: auto;
    padding-top: var(--space-4);
    border-top: var(--hairline);
    color: var(--text-secondary);
    font-size: 0.8rem;
  }
  .sec-card:hover .sec-go {
    color: var(--red-hover);
  }
  @media (max-width: 520px) {
    .stats {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 720px) {
    .lander-title {
      font-size: 2.35rem;
    }
    .sec-card {
      padding: var(--space-4);
    }
  }
</style>
