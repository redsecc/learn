---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getDocsBySection, SECTIONS } from '../lib/docs';
import { pageSlugOf } from '../lib/docs';
import { withBase } from '../lib/base';

const groups = await getDocsBySection();
// First page of each section, for "jump in" links.
const firstPageHref = (slug: string) => {
  const g = groups.find((g) => g.section.slug === slug);
  if (!g || g.pages.length === 0) return withBase(`/${slug}`);
  return withBase(`/${slug}/${pageSlugOf(g.pages[0].id)}`);
};
const start = firstPageHref('getting-started');
---

<BaseLayout
  title="Docs"
  description="The RedSec learning platform — a free, open guide to offensive security: CTFs, bug bounties, and finding vulnerabilities."
>
  <section class="lander">
    <div class="container">
      <span class="eyebrow">Learn · learn.redsec.cc</span>
      <h1 class="lander-title">RedSec docs</h1>
      <p class="lead">
        A free, open guide to offensive security. Work through it like a
        handbook — pick a section, follow the pages in order, or jump straight to
        what you need from the sidebar.
      </p>
      <div class="lander-actions">
        <a class="btn btn-primary" href={start}>Start reading →</a>
        <a class="btn" href="https://redsec.cc">redsec.cc ↗</a>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="grid grid-2">
        {
          groups.map(({ section, pages }) => (
            <a class="sec-card" href={firstPageHref(section.slug)}>
              <div class="sec-top">
                <span class="sec-icon mono" aria-hidden="true">{section.icon}</span>
                <span class="sec-count mono">{pages.length} {pages.length === 1 ? 'page' : 'pages'}</span>
              </div>
              <h2 class="sec-title">{section.title}</h2>
              <p class="sec-summary">{section.summary}</p>
              <span class="sec-go mono" aria-hidden="true">Open →</span>
            </a>
          ))
        }
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .lander {
    padding-block: var(--space-24) var(--space-12);
    border-bottom: var(--hairline);
  }
  .lander-title {
    font-size: clamp(2.25rem, 6vw, 3.5rem);
    margin-bottom: var(--space-6);
  }
  .lander .lead {
    max-width: var(--maxw-prose);
  }
  .lander-actions {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-3);
    margin-top: var(--space-8);
  }
  .sec-card {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    background: var(--surface);
    border: var(--hairline);
    border-radius: var(--radius);
    padding: var(--space-6);
    color: var(--text);
    height: 100%;
    transition: background 0.15s ease, border-color 0.15s ease, transform 0.15s ease;
  }
  .sec-card:hover {
    background: var(--elevated);
    border-color: var(--text-muted);
    text-decoration: none;
    transform: translateY(-2px);
  }
  .sec-top {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }
  .sec-icon {
    color: var(--red);
    font-size: 1.1rem;
  }
  .sec-count {
    color: var(--text-muted);
    font-size: 0.8rem;
  }
  .sec-title {
    margin: 0;
    font-size: 1.2rem;
  }
  .sec-summary {
    margin: 0;
    color: var(--text-secondary);
    font-size: 0.95rem;
  }
  .sec-go {
    margin-top: auto;
    padding-top: var(--space-4);
    border-top: var(--hairline);
    color: var(--text-secondary);
    font-size: 0.8rem;
  }
  .sec-card:hover .sec-go {
    color: var(--red-hover);
  }
</style>
