---
import { render } from 'astro:content';
import DocsLayout from '../../layouts/DocsLayout.astro';
import TableOfContents from '../../components/TableOfContents.astro';
import Callout from '../../components/Callout.astro';
import { getSortedDocs, sectionOf, pageSlugOf, sectionMeta } from '../../lib/docs';
import { withBase } from '../../lib/base';
import { abs, breadcrumb, ORG_REF, SITE_REF } from '../../lib/seo';

export async function getStaticPaths() {
  const docs = await getSortedDocs();
  return docs.map((doc, i) => ({
    params: { section: sectionOf(doc.id), slug: pageSlugOf(doc.id) },
    props: {
      doc,
      prev: i > 0 ? docs[i - 1] : null,
      next: i < docs.length - 1 ? docs[i + 1] : null,
    },
  }));
}

const { doc, prev, next } = Astro.props;
const section = sectionMeta(sectionOf(doc.id));
const { Content, headings } = await render(doc);

const hrefFor = (d: typeof doc) => withBase(`/${sectionOf(d.id)}/${pageSlugOf(d.id)}`);

const jsonLd = [
  {
    '@type': 'TechArticle',
    headline: doc.data.title,
    description: doc.data.summary,
    url: abs(`/${doc.id}`),
    keywords: doc.data.tags.join(', '),
    articleSection: section?.title,
    inLanguage: 'en',
    author: ORG_REF,
    publisher: ORG_REF,
    isPartOf: SITE_REF,
  },
  breadcrumb([
    ...(section ? [{ name: section.title, path: `/${section.slug}` }] : []),
    { name: doc.data.title, path: `/${doc.id}` },
  ]),
];
---

<DocsLayout
  title={doc.data.title}
  description={doc.data.summary ?? `${doc.data.title} — RedSec docs`}
  current={doc.id}
  currentSection={section?.slug}
  jsonLd={jsonLd}
>
  <nav class="crumbs mono" aria-label="Breadcrumb">
    <a href={withBase('/')}>docs</a>
    <span aria-hidden="true">/</span>
    {section && <a href={withBase(`/${section.slug}`)}>{section.slug}</a>}
    <span aria-hidden="true">/</span>
    <span>{pageSlugOf(doc.id)}</span>
  </nav>

  <header class="doc-head">
    {section && <span class="eyebrow">{section.title}</span>}
    <h1>{doc.data.title}</h1>
    {doc.data.summary && <p class="lead">{doc.data.summary}</p>}
  </header>

  <div class="prose">
    <Content components={{ Callout }} />
  </div>

  <nav class="prevnext" aria-label="Page navigation">
    {
      prev ? (
        <a class="pn-link prev" href={hrefFor(prev)}>
          <span class="pn-dir mono">← Previous</span>
          <span class="pn-title">{prev.data.title}</span>
        </a>
      ) : (
        <span />
      )
    }
    {
      next ? (
        <a class="pn-link next" href={hrefFor(next)}>
          <span class="pn-dir mono">Next →</span>
          <span class="pn-title">{next.data.title}</span>
        </a>
      ) : (
        <span />
      )
    }
  </nav>

  <TableOfContents slot="toc" headings={headings} />
</DocsLayout>

<style>
  .crumbs {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
    font-size: 0.8rem;
    color: var(--text-muted);
    margin-bottom: var(--space-6);
  }
  .crumbs a {
    color: var(--text-secondary);
  }
  .doc-head {
    margin-bottom: var(--space-8);
  }
  .doc-head h1 {
    margin-bottom: var(--space-4);
  }
  .prevnext {
    display: grid;
    gap: var(--space-4);
    margin-top: var(--space-12);
    padding-top: var(--space-8);
    border-top: var(--hairline);
  }
  @media (min-width: 560px) {
    .prevnext {
      grid-template-columns: 1fr 1fr;
    }
  }
  .pn-link {
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
    padding: var(--space-4);
    background: var(--surface);
    border: var(--hairline);
    border-radius: var(--radius);
    color: var(--text);
  }
  .pn-link:hover {
    background: var(--elevated);
    border-color: var(--text-muted);
    text-decoration: none;
  }
  .pn-link.next {
    text-align: right;
  }
  .pn-dir {
    font-size: 0.72rem;
    color: var(--text-muted);
  }
  .pn-title {
    color: var(--text);
    font-weight: 500;
  }
  .pn-link:hover .pn-dir {
    color: var(--red-hover);
  }
</style>
