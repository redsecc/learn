---
import { render } from 'astro:content';
import LearnLayout from '../../layouts/LearnLayout.astro';
import TableOfContents from '../../components/TableOfContents.astro';
import Callout from '../../components/Callout.astro';
import { getSortedLessons, sectionOf, pageSlugOf, sectionMeta } from '../../lib/learn';
import { withBase } from '../../lib/base';
import { abs, breadcrumb, ORG_REF, SITE_REF } from '../../lib/seo';

export async function getStaticPaths() {
  const lessons = await getSortedLessons();
  return lessons.map((lesson, i) => ({
    params: { section: sectionOf(lesson.id), slug: pageSlugOf(lesson.id) },
    props: {
      lesson,
      prev: i > 0 ? lessons[i - 1] : null,
      next: i < lessons.length - 1 ? lessons[i + 1] : null,
    },
  }));
}

const { lesson, prev, next } = Astro.props;
const section = sectionMeta(sectionOf(lesson.id));
const { Content, headings } = await render(lesson);

const hrefFor = (d: typeof lesson) => withBase(`/${sectionOf(d.id)}/${pageSlugOf(d.id)}`);

const jsonLd = [
  {
    '@type': 'TechArticle',
    headline: lesson.data.title,
    description: lesson.data.summary,
    url: abs(`/${lesson.id}`),
    keywords: lesson.data.tags.join(', '),
    articleSection: section?.title,
    inLanguage: 'en',
    author: ORG_REF,
    publisher: ORG_REF,
    isPartOf: SITE_REF,
  },
  breadcrumb([
    ...(section ? [{ name: section.title, path: `/${section.slug}` }] : []),
    { name: lesson.data.title, path: `/${lesson.id}` },
  ]),
];
---

<LearnLayout
  title={lesson.data.title}
  description={lesson.data.summary ?? `${lesson.data.title} — RedSec learning`}
  current={lesson.id}
  currentSection={section?.slug}
  jsonLd={jsonLd}
>
  <nav class="crumbs mono" aria-label="Breadcrumb">
    <a href={withBase('/')}>learn</a>
    <span aria-hidden="true">/</span>
    {section && <a href={withBase(`/${section.slug}`)}>{section.slug}</a>}
    <span aria-hidden="true">/</span>
    <span>{pageSlugOf(lesson.id)}</span>
  </nav>

  <header class="lesson-head">
    {section && <span class="eyebrow">{section.title}</span>}
    <h1>{lesson.data.title}</h1>
    {lesson.data.summary && <p class="lead">{lesson.data.summary}</p>}
    <div class="lesson-meta" aria-label="Lesson metadata">
      <span class="chip" data-difficulty={lesson.data.level}>{lesson.data.level}</span>
      <span class="chip">{lesson.data.kind}</span>
      {lesson.data.duration && <span class="chip">{lesson.data.duration}</span>}
    </div>
  </header>

  <div class="prose">
    <Content components={{ Callout }} />
  </div>

  <nav class="prevnext" aria-label="Page navigation">
    {
      prev ? (
        <a class="pn-link prev" href={hrefFor(prev)}>
          <span class="pn-dir mono">← Previous</span>
          <span class="pn-title">{prev.data.title}</span>
        </a>
      ) : (
        <span />
      )
    }
    {
      next ? (
        <a class="pn-link next" href={hrefFor(next)}>
          <span class="pn-dir mono">Next →</span>
          <span class="pn-title">{next.data.title}</span>
        </a>
      ) : (
        <span />
      )
    }
  </nav>

  <TableOfContents slot="toc" headings={headings} />
</LearnLayout>

<style>
  .crumbs {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
    font-size: 0.8rem;
    color: var(--text-muted);
    margin-bottom: var(--space-6);
  }
  .crumbs a {
    color: var(--text-secondary);
  }
  .lesson-head {
    margin-bottom: var(--space-8);
  }
  .lesson-head h1 {
    margin-bottom: var(--space-4);
  }
  .lesson-meta {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
    margin-top: var(--space-4);
  }
  .prevnext {
    display: grid;
    gap: var(--space-4);
    margin-top: var(--space-12);
    padding-top: var(--space-8);
    border-top: var(--hairline);
  }
  @media (min-width: 560px) {
    .prevnext {
      grid-template-columns: 1fr 1fr;
    }
  }
  .pn-link {
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
    padding: var(--space-4);
    background: var(--surface);
    border: var(--hairline);
    border-radius: var(--radius);
    color: var(--text);
  }
  .pn-link:hover {
    background: var(--elevated);
    border-color: var(--text-muted);
    text-decoration: none;
  }
  .pn-link.next {
    text-align: right;
  }
  .pn-dir {
    font-size: 0.72rem;
    color: var(--text-muted);
  }
  .pn-title {
    color: var(--text);
    font-weight: 500;
  }
  .pn-link:hover .pn-dir {
    color: var(--red-hover);
  }

  @media (max-width: 559px) {
    .pn-link.next {
      text-align: left;
    }
  }
</style>
