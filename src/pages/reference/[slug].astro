---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import TableOfContents from '../../components/TableOfContents.astro';
import Callout from '../../components/Callout.astro';
import { withBase } from '../../lib/base';
import { abs, breadcrumb, ORG_REF, SITE_REF } from '../../lib/seo';

export async function getStaticPaths() {
  const refs = await getCollection('reference');
  return refs.map((ref) => ({ params: { slug: ref.id }, props: { ref } }));
}

const { ref } = Astro.props;
const { Content, headings } = await render(ref);

const jsonLd = [
  {
    '@type': 'Article',
    headline: ref.data.title,
    description: ref.data.summary,
    url: abs(`/reference/${ref.id}`),
    keywords: ref.data.tags.join(', '),
    inLanguage: 'en',
    author: ORG_REF,
    publisher: ORG_REF,
    isPartOf: SITE_REF,
  },
  breadcrumb([
    { name: 'Reference', path: '/reference' },
    { name: ref.data.title, path: `/reference/${ref.id}` },
  ]),
];
---

<BaseLayout
  title={ref.data.title}
  description={ref.data.summary}
  ogType="article"
  keywords={ref.data.tags}
  jsonLd={jsonLd}
>
  <div class="container ref-shell">
    <div class="ref-grid">
      <aside class="ref-aside">
        <TableOfContents headings={headings} />
      </aside>

      <article class="ref-main">
        <nav class="crumbs mono" aria-label="Breadcrumb">
          <a href={withBase('/reference')}>reference</a>
          <span aria-hidden="true">/</span>
          <span>{ref.id}</span>
        </nav>

        <header class="ref-header">
          <span class="eyebrow">Reference</span>
          <h1>{ref.data.title}</h1>
          <p class="lead">{ref.data.summary}</p>
        </header>

        <div class="prose">
          <Content components={{ Callout }} />
        </div>
      </article>
    </div>
  </div>
</BaseLayout>

<style>
  .ref-shell {
    padding-block: var(--space-12) var(--space-16);
  }
  .ref-grid {
    display: grid;
    gap: var(--space-12);
  }
  @media (min-width: 900px) {
    .ref-grid {
      grid-template-columns: 15rem minmax(0, 1fr);
    }
  }
  .ref-main {
    min-width: 0;
    max-width: var(--maxw-prose);
  }
  .crumbs {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
    font-size: 0.8rem;
    color: var(--text-muted);
    margin-bottom: var(--space-6);
  }
  .crumbs a {
    color: var(--text-secondary);
  }
  .ref-header {
    margin-bottom: var(--space-8);
  }
  .ref-header h1 {
    margin-bottom: var(--space-4);
  }
</style>
