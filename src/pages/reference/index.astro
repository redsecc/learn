---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { withBase } from '../../lib/base';

const refs = (await getCollection('reference')).sort(
  (a, b) => a.data.order - b.data.order
);
---

<BaseLayout
  title="Reference"
  description="Cheatsheets and quick reference for red teaming — enumeration checklists, common ports, and more."
>
  <section class="section">
    <div class="container">
      <header class="page-head">
        <span class="eyebrow">Reference</span>
        <h1>Cheatsheets &amp; quick reference</h1>
        <p class="lead">
          Fast lookups for when you're mid-engagement and just need the command.
        </p>
      </header>

      <ul class="ref-list">
        {
          refs.map((ref) => (
            <li>
              <a class="ref-card" href={withBase(`/reference/${ref.id}`)}>
                <div>
                  <h3 class="ref-title">{ref.data.title}</h3>
                  <p class="ref-summary">{ref.data.summary}</p>
                </div>
                <span class="ref-go mono" aria-hidden="true">→</span>
              </a>
            </li>
          ))
        }
      </ul>
    </div>
  </section>
</BaseLayout>

<style>
  .page-head {
    max-width: var(--maxw-prose);
    margin-bottom: var(--space-12);
  }
  .page-head h1 {
    margin-bottom: var(--space-4);
  }
  .ref-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    max-width: 48rem;
  }
  .ref-card {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-4);
    background: var(--surface);
    border: var(--hairline);
    border-radius: var(--radius);
    padding: var(--space-4) var(--space-6);
    color: var(--text);
    transition: background 0.15s ease, border-color 0.15s ease;
  }
  .ref-card:hover {
    background: var(--elevated);
    border-color: var(--text-muted);
    text-decoration: none;
  }
  .ref-title {
    margin: 0 0 var(--space-1);
    font-size: 1.05rem;
  }
  .ref-summary {
    margin: 0;
    color: var(--text-secondary);
    font-size: 0.9rem;
  }
  .ref-go {
    color: var(--text-muted);
    font-size: 1.1rem;
  }
  .ref-card:hover .ref-go {
    color: var(--red-hover);
  }
</style>
