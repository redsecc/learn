---
// Inline the actual src/assets/redsec_logo.svg contents. Using `?raw` keeps
// the mark crisp at any size, lets it inherit color, and means dropping in the
// real logo file updates the whole site with no other changes.
import logoRaw from '../assets/redsec_logo.svg?raw';

interface Props {
  size?: number;
  class?: string;
}
const { size = 32, class: className } = Astro.props;
---

<span
  class:list={['logo', className]}
  style={`width:${size}px;height:${size}px`}
  aria-hidden="true"
  set:html={logoRaw}
/>

<style is:global>
  .logo {
    display: inline-flex;
    flex: none;
    line-height: 0;
  }
  .logo svg {
    width: 100%;
    height: 100%;
    display: block;
  }
</style>
