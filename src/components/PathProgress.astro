---
// Per-path progress bar. Island backed by localStorage only.
interface Props {
  lessons: string[]; // ordered lesson slugs in this path
  showReset?: boolean;
}
const { lessons, showReset = false } = Astro.props;
const total = lessons.length;
---

<path-progress
  class="path-progress"
  data-lessons={lessons.join(',')}
  data-show-reset={showReset ? 'true' : 'false'}
>
  <div class="pp-head">
    <span class="pp-count mono">0 / {total} complete</span>
    <span class="pp-pct mono">0%</span>
  </div>
  <div
    class="pp-bar"
    role="progressbar"
    aria-valuemin="0"
    aria-valuemax={total}
    aria-valuenow="0"
    aria-label="Path progress"
  >
    <span class="pp-fill"></span>
  </div>
  <div class="pp-foot">
    <span class="pp-note mono">Progress saved on this device</span>
    {showReset && <button class="pp-reset mono" type="button">Reset progress</button>}
  </div>
</path-progress>

<script>
  import { getCompleted, resetProgress, storageAvailable, onChange } from '../scripts/progress';

  class PathProgress extends HTMLElement {
    connectedCallback() {
      const lessons = (this.dataset.lessons || '').split(',').filter(Boolean);
      const total = lessons.length;
      const countEl = this.querySelector<HTMLElement>('.pp-count')!;
      const pctEl = this.querySelector<HTMLElement>('.pp-pct')!;
      const bar = this.querySelector<HTMLElement>('.pp-bar')!;
      const fill = this.querySelector<HTMLElement>('.pp-fill')!;
      const note = this.querySelector<HTMLElement>('.pp-note')!;
      const reset = this.querySelector<HTMLButtonElement>('.pp-reset');

      if (!storageAvailable()) {
        note.textContent = 'Progress needs on-device storage (unavailable).';
        if (reset) reset.hidden = true;
        return;
      }

      const render = () => {
        const done = new Set(getCompleted());
        const completed = lessons.filter((s) => done.has(s)).length;
        const pct = total ? Math.round((completed / total) * 100) : 0;
        countEl.textContent = `${completed} / ${total} complete`;
        pctEl.textContent = `${pct}%`;
        fill.style.width = `${pct}%`;
        bar.setAttribute('aria-valuenow', String(completed));
        // reflect completion on any lesson cards in this document
        document.querySelectorAll<HTMLElement>('[data-lesson]').forEach((el) => {
          const s = el.dataset.lesson!;
          if (lessons.includes(s)) {
            el.setAttribute('data-complete', String(done.has(s)));
          }
        });
      };

      reset?.addEventListener('click', () => {
        if (confirm('Reset all on-device progress? This cannot be undone.')) {
          resetProgress();
        }
      });
      onChange(render);
      render();
    }
  }
  if (!customElements.get('path-progress')) {
    customElements.define('path-progress', PathProgress);
  }
</script>

<style>
  .path-progress {
    display: block;
  }
  .pp-head {
    display: flex;
    justify-content: space-between;
    margin-bottom: var(--space-2);
    font-size: 0.8rem;
    color: var(--text-secondary);
  }
  .pp-pct {
    color: var(--text);
  }
  .pp-bar {
    height: 6px;
    background: var(--elevated);
    border: var(--hairline);
    border-radius: 999px;
    overflow: hidden;
  }
  .pp-fill {
    display: block;
    height: 100%;
    width: 0;
    background: var(--red);
    transition: width 0.3s ease;
  }
  .pp-foot {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-top: var(--space-2);
  }
  .pp-note {
    font-size: 0.72rem;
    color: var(--text-muted);
  }
  .pp-reset {
    background: none;
    border: none;
    padding: 0;
    color: var(--text-muted);
    font-size: 0.72rem;
    cursor: pointer;
    text-decoration: underline;
    text-underline-offset: 2px;
  }
  .pp-reset:hover {
    color: var(--red-hover);
  }
</style>
