---
import { withBase } from '../lib/base';

interface Props {
  title: string;
  summary: string;
  slug: string;
  difficulty?: 'intro' | 'core' | 'advanced';
  order?: number;
  tags?: string[];
}
const { title, summary, slug, difficulty, order, tags = [] } = Astro.props;
const href = withBase(`/lessons/${slug}`);
---

<a class="lesson-card" href={href} data-lesson={slug}>
  <span class="lesson-status" aria-hidden="true"></span>
  <div class="lesson-body">
    <div class="lesson-head">
      {order != null && <span class="lesson-index mono">{String(order).padStart(2, '0')}</span>}
      <h3 class="lesson-title">{title}</h3>
    </div>
    <p class="lesson-summary">{summary}</p>
    <div class="lesson-meta">
      {difficulty && (
        <span class="chip" data-difficulty={difficulty}>{difficulty}</span>
      )}
      {tags.slice(0, 3).map((t) => <span class="chip">{t}</span>)}
    </div>
  </div>
  <span class="lesson-go mono" aria-hidden="true">→</span>
</a>

<style>
  .lesson-card {
    display: flex;
    align-items: stretch;
    gap: var(--space-4);
    background: var(--surface);
    border: var(--hairline);
    border-radius: var(--radius);
    padding: var(--space-4) var(--space-6);
    color: var(--text);
    transition: background 0.15s ease, border-color 0.15s ease;
  }
  .lesson-card:hover {
    background: var(--elevated);
    border-color: var(--text-muted);
    text-decoration: none;
  }
  /* completion dot, filled by the progress island */
  .lesson-status {
    flex: none;
    align-self: center;
    width: 9px;
    height: 9px;
    border-radius: 999px;
    border: 1px solid var(--text-muted);
    background: transparent;
  }
  .lesson-card[data-complete='true'] .lesson-status {
    background: var(--red);
    border-color: var(--red);
  }
  .lesson-body {
    flex: 1;
    min-width: 0;
  }
  .lesson-head {
    display: flex;
    align-items: baseline;
    gap: var(--space-3);
  }
  .lesson-index {
    color: var(--text-muted);
    font-size: 0.8rem;
  }
  .lesson-title {
    margin: 0;
    font-size: 1.05rem;
  }
  .lesson-summary {
    margin: var(--space-1) 0 var(--space-3);
    color: var(--text-secondary);
    font-size: 0.9rem;
  }
  .lesson-meta {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
  }
  .lesson-go {
    align-self: center;
    color: var(--text-muted);
    font-size: 1.1rem;
  }
  .lesson-card:hover .lesson-go {
    color: var(--red-hover);
  }
</style>
