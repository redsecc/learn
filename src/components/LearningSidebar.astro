---
import { getLessonsBySection, pageSlugOf } from '../lib/learn';
import { withBase } from '../lib/base';

interface Props {
  current?: string; // current lesson id, e.g. "ctfs/intro"
  currentSection?: string; // active section slug (for section index pages)
}
const { current, currentSection } = Astro.props;
const groups = await getLessonsBySection();
---

<nav class="learn-sidebar" aria-label="Learning library">
  <details class="ds-details" open>
    <summary class="ds-summary mono">Learning library</summary>
    <div class="ds-body">
      {
        groups.map(({ section, pages }) => {
          const active = section.slug === currentSection;
          return active ? (
            <details class="ds-group" open>
              <summary class="ds-section active">
                <span>{section.title}</span>
                <span class="ds-count mono">{pages.length}</span>
              </summary>
              <a
                class:list={['ds-link', 'ds-overview', { active: !current }]}
                href={withBase(`/${section.slug}`)}
              >
                Overview
              </a>
              <ul>
                {pages.map((p) => (
                  <li>
                    <a
                      class:list={['ds-link', { active: p.id === current }]}
                      href={withBase(`/${section.slug}/${pageSlugOf(p.id)}`)}
                      aria-current={p.id === current ? 'page' : undefined}
                    >
                      {p.data.title}
                    </a>
                  </li>
                ))}
              </ul>
            </details>
          ) : (
            <a class="ds-group ds-section-link" href={withBase(`/${section.slug}`)}>
              <span>{section.title}</span>
              <span class="ds-count mono">{pages.length}</span>
            </a>
          );
        })
      }
    </div>
  </details>
</nav>

<style>
  .learn-sidebar {
    position: sticky;
    top: 5rem;
    font-size: 0.9rem;
    max-height: calc(100vh - 6rem);
    overflow: auto;
    padding-right: var(--space-2);
    scrollbar-width: thin;
  }
  .ds-summary {
    color: var(--text-muted);
    font-size: 0.72rem;
    letter-spacing: 0.06em;
    margin-bottom: var(--space-4);
    list-style: none;
    cursor: default;
    pointer-events: none;
  }
  .ds-summary::-webkit-details-marker {
    display: none;
  }
  .ds-body {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }
  .ds-group {
    border-bottom: var(--hairline);
    padding-bottom: var(--space-2);
  }
  .ds-section-link {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-3);
    color: var(--text-secondary);
    padding: 0.35rem 0 var(--space-2);
  }
  .ds-section-link:hover {
    color: var(--text);
    text-decoration: none;
  }
  .ds-section {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-3);
    font-weight: 500;
    color: var(--text);
    padding: 0.35rem 0;
    cursor: pointer;
    list-style: none;
  }
  .ds-section::-webkit-details-marker {
    display: none;
  }
  .ds-section::before {
    content: '+';
    color: var(--text-muted);
    font-family: var(--font-mono);
    font-size: 0.8rem;
    margin-right: var(--space-1);
  }
  .ds-group[open] .ds-section::before {
    content: '-';
  }
  .ds-section.active {
    color: var(--red-hover);
  }
  .ds-section:hover {
    color: var(--red-hover);
    text-decoration: none;
  }
  .ds-count {
    color: var(--text-muted);
    font-size: 0.72rem;
    font-weight: 400;
    margin-left: auto;
  }
  .learn-sidebar ul {
    list-style: none;
    margin: 0;
    padding: 0;
    border-left: var(--hairline);
  }
  .ds-link {
    display: block;
    padding: 0.3rem 0 0.3rem var(--space-4);
    margin-left: -1px;
    border-left: 1px solid transparent;
    color: var(--text-secondary);
    line-height: 1.35;
  }
  .ds-link:hover {
    color: var(--text);
    text-decoration: none;
  }
  .ds-link.active {
    color: var(--red-hover);
    border-left-color: var(--red);
  }
  .ds-overview {
    border-left: var(--hairline);
    color: var(--text-muted);
    font-family: var(--font-mono);
    font-size: 0.76rem;
  }

  /* Collapsible on mobile, always-open on desktop. */
  @media (max-width: 900px) {
    .learn-sidebar {
      position: static;
      border: var(--hairline);
      border-radius: var(--radius);
      padding: var(--space-3) var(--space-4);
      max-height: none;
      overflow: visible;
    }
    .ds-summary {
      cursor: pointer;
      pointer-events: auto;
      margin-bottom: 0;
    }
    .ds-summary::-webkit-details-marker {
      display: revert;
    }
    .ds-details[open] .ds-summary {
      margin-bottom: var(--space-4);
    }
  }
</style>
