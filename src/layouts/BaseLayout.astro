---
// Self-hosted fonts — two weights each, no third-party (Google) requests.
import '@fontsource/inter/400.css';
import '@fontsource/inter/500.css';
import '@fontsource/jetbrains-mono/400.css';
import '@fontsource/jetbrains-mono/500.css';
import '../styles/global.css';

import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { withBase } from '../lib/base';
import { SITE } from '../lib/site';

interface Props {
  title?: string;
  description?: string;
  ogType?: 'website' | 'article';
  /** Path (base-relative) or absolute URL to a social image. */
  image?: string;
  keywords?: string[];
  /** Extra JSON-LD nodes to merge with the site-wide graph. */
  jsonLd?: Record<string, unknown> | Record<string, unknown>[];
  /** ISO date for article-type pages. */
  publishedTime?: string;
  noindex?: boolean;
}

const {
  title,
  description = SITE.description,
  ogType = 'website',
  image = SITE.ogImage,
  keywords = SITE.keywords,
  jsonLd,
  publishedTime,
  noindex = false,
} = Astro.props;

const pageTitle = title ? `${title} · ${SITE.name}` : `${SITE.name} — ${SITE.tagline}`;
const canonical = new URL(Astro.url.pathname, Astro.site ?? SITE.url).href;
const favicon = withBase('/favicon.svg');

// Resolve social image to an absolute URL (required by social scrapers).
const imageUrl = image.startsWith('http')
  ? image
  : new URL(withBase(image), Astro.site ?? SITE.url).href;

// Site-wide structured data: who publishes this and what the site is.
const orgLd = {
  '@type': 'Organization',
  '@id': `${SITE.url}/#org`,
  name: SITE.name,
  url: SITE.url,
  description: SITE.description,
  logo: new URL(withBase('/favicon.svg'), SITE.url).href,
  sameAs: [SITE.social.github, SITE.social.discord],
};
const siteLd = {
  '@type': 'WebSite',
  '@id': `${SITE.url}/#website`,
  name: SITE.name,
  url: SITE.url,
  description: SITE.description,
  inLanguage: 'en',
  publisher: { '@id': `${SITE.url}/#org` },
};

const extra = jsonLd ? (Array.isArray(jsonLd) ? jsonLd : [jsonLd]) : [];
const graph = {
  '@context': 'https://schema.org',
  '@graph': [orgLd, siteLd, ...extra],
};
---

<!doctype html>
<html lang="en" data-theme="dark">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <meta name="keywords" content={keywords.join(', ')} />
    <link rel="canonical" href={canonical} />
    <meta
      name="robots"
      content={noindex ? 'noindex, nofollow' : 'index, follow, max-image-preview:large'}
    />
    <meta name="generator" content={Astro.generator} />

    <!-- SVG favicon derived from the logo mark -->
    <link rel="icon" type="image/svg+xml" href={favicon} />
    <meta name="theme-color" content="#0E0E0E" />
    <meta name="color-scheme" content="dark" />

    <!-- Open Graph / social -->
    <meta property="og:type" content={ogType} />
    <meta property="og:site_name" content={SITE.name} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:locale" content={SITE.locale} />
    <meta property="og:image" content={imageUrl} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={`${SITE.name} — ${SITE.tagline}`} />
    {ogType === 'article' && publishedTime && (
      <meta property="article:published_time" content={publishedTime} />
    )}

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={imageUrl} />
    <meta name="twitter:image:alt" content={`${SITE.name} — ${SITE.tagline}`} />

    <!-- Discovery. This site sets no cookies, ships no analytics, no third-party requests. -->
    <link rel="sitemap" href={withBase('/sitemap-index.xml')} />

    <!-- Structured data -->
    <script type="application/ld+json" set:html={JSON.stringify(graph)} />
  </head>
  <body>
    <a class="skip-link" href="#main">Skip to content</a>
    <Header />
    <main id="main">
      <slot />
    </main>
    <Footer />
  </body>
</html>
