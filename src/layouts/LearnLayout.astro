---
import BaseLayout from './BaseLayout.astro';
import LearningSidebar from '../components/LearningSidebar.astro';

interface Props {
  title?: string;
  description?: string;
  current?: string;
  currentSection?: string;
  jsonLd?: Record<string, unknown> | Record<string, unknown>[];
}
const { title, description, current, currentSection, jsonLd } = Astro.props;
const hasToc = Astro.slots.has('toc');
---

<BaseLayout title={title} description={description} ogType="article" jsonLd={jsonLd}>
  <div class:list={['learn-layout', 'container', { 'has-toc': hasToc }]}>
    <aside class="learn-aside">
      <LearningSidebar current={current} currentSection={currentSection} />
    </aside>
    <article class="learn-main">
      <slot />
    </article>
    {hasToc && (
      <aside class="learn-toccol">
        <slot name="toc" />
      </aside>
    )}
  </div>
</BaseLayout>

<style>
  .learn-layout {
    display: grid;
    gap: var(--space-8);
    padding-block: var(--space-8) var(--space-16);
  }
  .learn-main {
    min-width: 0;
    max-width: var(--maxw-prose);
  }
  @media (min-width: 900px) {
    .learn-layout {
      grid-template-columns: 17rem minmax(0, 1fr);
      gap: var(--space-12);
    }
  }
  @media (min-width: 1200px) {
    .learn-layout.has-toc {
      grid-template-columns: 17rem minmax(0, 1fr) 13rem;
    }
  }
  /* TOC column only on wide screens; sidebar is the primary nav otherwise. */
  .learn-toccol {
    display: none;
  }
  @media (min-width: 1200px) {
    .learn-layout.has-toc .learn-toccol {
      display: block;
    }
  }
</style>
